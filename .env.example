# Copiar a .env y ajustar valores base del entorno.
# .env.local (opcional) sobrescribe .env para desarrollo local sin commitear secretos.

# Opcion A: URL completa (tiene prioridad sobre variables individuales)
# DATABASE_URL=postgresql+psycopg://postgres:secret@localhost:5432/metrocali_audit

# Opcion B: variables individuales para armar el engine facilmente
DB_DRIVER=postgresql+psycopg
DB_HOST=localhost
DB_PORT=5432
DB_NAME=metrocali_audit
DB_USER=postgres
DB_PASSWORD=secret

# Si true, usa FakeConnectionRepository (sin base de datos real)
USE_FAKE_CONNECTION_REPOSITORY=false

# En desarrollo, la contraseña puede estar sin cifrar en encrypted_password
PASSWORD_PLAINTEXT_MODE=true
